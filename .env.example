ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key-here
ADMIN_PASSWORD=change-me

# Base URL of the deployed app (used for Google OAuth redirects)
APP_URL=http://localhost:3000

# Optional — Google sign-in. Create a free OAuth "Web application" client at
# console.cloud.google.com → APIs & Services → Credentials, with authorized
# redirect URI: <APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
